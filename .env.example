# Local dev (SQLite — ไม่ต้องติดตั้ง PostgreSQL)
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL)
# DATABASE_URL="postgresql://talkto:talkto@localhost:5432/talkto"
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3010"
PORT=3010

# อีเมลที่ได้รับ ADMIN ตอนสมัคร (คั่นด้วย comma) — ถ้ายังไม่มี admin คนแรกจะเป็น ADMIN อัตโนมัติ
# ADMIN_EMAILS="admin@example.com"

# Cloudinary (ส่งรูปในแชท)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
