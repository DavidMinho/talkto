# คัดลอกค่าเหล่านี้ไปใส่ใน Render → Environment (ห้าม commit ไฟล์นี้ถ้ามี secret จริง)

# Neon → Connection Details → ใช้ "Direct connection" (ไม่ใช่ pooled) สำหรับ migrate
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ใส่หลัง deploy รู้ URL แล้ว เช่น https://talkto-xxxx.onrender.com
NEXTAUTH_URL=https://YOUR-APP.onrender.com

# Render สร้างให้อัตโนมัติได้ หรือรัน: openssl rand -base64 32
NEXTAUTH_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# optional — อีเมลที่จะเป็น admin ตอนสมัคร
ADMIN_EMAILS=
