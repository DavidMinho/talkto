{
  "name": "talkto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && tsx server.ts",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:prod": "prisma migrate deploy && NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:promote-admin": "tsx scripts/promote-admin.ts",
    "docs:features-pdf": "tsx scripts/generate-features-pdf.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:${PORT:-3010}",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.0",
    "@mui/material": "^9.1.0",
    "@mui/material-nextjs": "^9.1.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "isomorphic-dompurify": "^3.16.0",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-react": "^5.32.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "pdfkit": "^0.19.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
